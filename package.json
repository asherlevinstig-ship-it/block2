{
  "name": "blockcraft-mp",
  "version": "1.0.0",
  "description": "Blockcraft — multiplayer voxel RPG on Colyseus",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "lint": "eslint .",
    "format:check": "node tools/check-format.js && git diff --check",
    "audit": "npm audit --audit-level=high",
    "check": "npm run lint && npm run format:check && npm test && npm run audit",
    "test": "node --test server/test/authority.test.js server/test/auth-integration.test.js server/test/auth.test.js server/test/client-modules.test.js server/test/metrics-registry.test.js server/test/persistence-failure.test.js server/test/progression-balance.test.js server/test/recall-room.test.js server/test/recall-system.test.js server/test/schema.test.js server/test/security-headers.test.js server/test/startup-config.test.js server/test/state-clusters.test.js server/test/store-selection.test.js",
    "test:integration": "node server/test/integration.test.js",
    "test:e2e": "playwright test",
    "test:event": "node tools/event-smoke-test.js",
    "test:load": "node tools/load-test.js",
    "test:load:shards": "node tools/shard-load-test.js",
    "test:load:dungeons": "node tools/dungeon-load-test.js",
    "test:soak:online": "node tools/online-soak-test.js",
    "test:perf": "node tools/perf-budget-test.js",
    "test:perf:client": "node tools/client-overworld-perf-test.js",
    "test:perf:interest": "node tools/interest-radius-matrix.js",
    "firebase:smoke": "node tools/firebase-smoke-test.js",
    "mysql:auth:smoke": "node tools/mysql-auth-smoke-test.js",
    "firebase:wipe:dry": "node tools/wipe-firestore.js --dry-run",
    "firebase:wipe": "node tools/wipe-firestore.js",
    "balance:loot": "node tools/loot-progression-sim.js",
    "balance:familiars": "node tools/familiar-balance-sim.js"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.44",
    "@colyseus/schema": "^4.0.27",
    "@colyseus/sdk": "^0.17.43",
    "@colyseus/ws-transport": "^0.17.13",
    "bcryptjs": "^3.0.3",
    "express": "^4.18.0",
    "firebase-admin": "^13.10.0",
    "mysql2": "^3.22.6",
    "three": "^0.128.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.4"
  }
}
