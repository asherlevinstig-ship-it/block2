# Template only: this app does not auto-load .env files today.
# Either export these in PowerShell before running locally, or configure them
# in your hosting provider's secrets/env-var panel.
# Never commit real credentials or Firebase service-account JSON.

# Use Firestore for game profiles/world persistence.
STORE=firebase

# Local development option: point at a downloaded Firebase Admin service account.
# In production, prefer your host's secret manager or FIREBASE_SERVICE_ACCOUNT.
GOOGLE_APPLICATION_CREDENTIALS=C:\absolute\path\to\firebase-service-account.json

# Production option: paste the full service-account JSON into a secret/env var.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Required in production by server/startup-config.js.
NODE_ENV=production
PUBLIC_URL=https://your-game-domain.example
TRUST_PROXY=1
DATA_DIR=C:\absolute\path\to\blockcraft-data

# Planned MySQL auth bridge for existing teacher/student accounts.
# Do not use the credentials pasted in chat; rotate them first.
AUTH_BACKEND=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_database_user
MYSQL_PASSWORD=change_me
MYSQL_PORT=3306
